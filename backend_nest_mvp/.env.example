PORT=8000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── ROL DE LA INSTÀNCIA ─────────────────────────────────────────────────────
# Controla quines parts del backend s'activen.
# Valor per defecte si NO es defineix: API_ENABLED=true, WORKER_ENABLED=true
# (mode local all-in-one — no cal canviar res per a desenvolupament local)
#
# VM Ubuntu (servidor principal, sense IA local):
#   WORKER_ENABLED=false
#   API_ENABLED=true
#
# Portàtil worker (processa jobs, sense servidor web):
#   WORKER_ENABLED=true
#   API_ENABLED=false
#
# WORKER_ENABLED=true
# API_ENABLED=true

# ── MONGO / REDIS ────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/sonilab
REDIS_HOST=localhost
REDIS_PORT=6379

# ── STORAGE ──────────────────────────────────────────────────────────────────
# STORAGE_ROOT té prioritat sobre MEDIA_ROOT si ambdós estan definits.
# Usa STORAGE_ROOT per a desplegament distribuït amb NAS compartit.
# Usa MEDIA_ROOT per a mode local (compatibilitat existent).
#
# Exemples:
#   STORAGE_ROOT=/mnt/sonilab_media          (Linux NAS mount)
#   STORAGE_ROOT=\\srv-copy\d\sonilab_media  (Windows UNC — millor muntar com a lletra)
MEDIA_ROOT=./media
# STORAGE_ROOT=

# ── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=12h

# ── WHISPERX / TRANSCRIPCIÓ ──────────────────────────────────────────────────
WHISPERX_PYTHON=/usr/bin/python3
WHISPERX_RUNNER=/absolute/path/to/whisperx_worker/src/runner_cli.py

WHISPERX_MODEL=large-v3
WHISPERX_ENGINE=faster-whisper
WHISPERX_PROFILE=VE
WHISPERX_LANGUAGE=es
WHISPERX_BATCH_SIZE=8
WHISPERX_DIARIZATION=false
WHISPERX_OFFLINE=false
WHISPERX_TIMING_FIX=true

# TRANSCRIBE_DEVICE: cpu | cuda — sobreescriu WHISPERX_DEVICE si s'especifica.
# Usa TRANSCRIBE_DEVICE per a configuració distribuïda (nom més clar).
# Usa WHISPERX_DEVICE per a compatibilitat local existent.
WHISPERX_DEVICE=cpu
# TRANSCRIBE_DEVICE=cpu

# ── PURFVIEW (Windows only) ──────────────────────────────────────────────────
# Opcional — si no existeix o el fitxer no existeix, usa pipeline Python.
# PURFVIEW_XXL_EXE_PATH=C:\...\faster-whisper-xxl.exe

# ── OLLAMA / LLM ─────────────────────────────────────────────────────────────
# URL de l'Ollama que usarà el worker per a correccions LLM.
# En mode local: http://127.0.0.1:11434 (Ollama a la mateixa màquina)
# En mode worker distribuït: http://127.0.0.1:11434 (Ollama local al portàtil)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# LLM_DEVICE=cpu  # (futur — ara Ollama gestiona device internament)

# ── OPCIONALS ────────────────────────────────────────────────────────────────
# HUGGINGFACE_HUB_TOKEN=
# FFMPEG_BIN=
# HF_HOME=
# PYTHON_RUNNER_DIR=../WhisperX_Sonilab_01-main/src

PORT=8000
CORS_ORIGINS=http://localhost:3000

# Mongo / Redis
MONGO_URI=mongodb://localhost:27017/sonilab
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
MEDIA_ROOT=./media

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# WhisperX runner
WHISPERX_PYTHON=/usr/bin/python3
WHISPERX_RUNNER=/absolute/path/to/whisperx_worker/src/runner_cli.py

WHISPERX_MODEL=small
WHISPERX_PROFILE=VE
WHISPERX_LANGUAGE=ca
WHISPERX_BATCH_SIZE=8
WHISPERX_DEVICE=cpu
WHISPERX_DIARIZATION=false
WHISPERX_OFFLINE=false

# Optional
HUGGINGFACE_HUB_TOKEN=
FFMPEG_BIN=
HF_HOME=

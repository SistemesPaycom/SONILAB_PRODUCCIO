# ============================================================
# .env.vm.example — VM Ubuntu (servidor principal)
# ============================================================
# Copia a .env i ajusta els valors reals.
# Rol: API + frontend. NO processa jobs IA localment.
# El portàtil worker connecta al Redis d'aquesta VM i processa els jobs.
# ============================================================

PORT=8000
NODE_ENV=production
CORS_ORIGINS=https://sonilab.example.com

# ── ROL ──────────────────────────────────────────────────────
# VM: serveix API però NO processa jobs de transcripció/IA
WORKER_ENABLED=false
API_ENABLED=true

# ── MONGO / REDIS (locals a la VM) ───────────────────────────
MONGO_URI=mongodb://localhost:27017/sonilab
REDIS_HOST=localhost
REDIS_PORT=6379

# ── STORAGE (NAS muntat) ─────────────────────────────────────
# Muntar NAS a /mnt/sonilab_media (via fstab o autofs)
STORAGE_ROOT=/mnt/sonilab_media

# ── AUTH ─────────────────────────────────────────────────────
# Usa el mateix JWT_SECRET que el worker (ha de coincidir!)
JWT_SECRET=canvia_aquest_secret_llarg_i_aleatori
JWT_EXPIRES_IN=12h

# ── WHISPERX (camins al Python/runner del worker, no de la VM) ─
# La VM no executa transcripció, però les variables s'hereten per
# si es vol fer fallback local ocasional (normalment no cal).
WHISPERX_PYTHON=/usr/bin/python3
WHISPERX_RUNNER=/opt/sonilab/runner/src/runner_cli.py
WHISPERX_MODEL=large-v3
WHISPERX_ENGINE=faster-whisper
WHISPERX_PROFILE=VE
WHISPERX_LANGUAGE=es
WHISPERX_BATCH_SIZE=8
WHISPERX_DEVICE=cpu
TRANSCRIBE_DEVICE=cpu
WHISPERX_DIARIZATION=false
WHISPERX_OFFLINE=false

# ── OLLAMA ───────────────────────────────────────────────────
# La VM no usa Ollama directament (el worker el té local).
# Deixa el valor per defecte per si es fa alguna crida local.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── OPCIONALS ────────────────────────────────────────────────
FFMPEG_BIN=/usr/bin/ffmpeg
# HUGGINGFACE_HUB_TOKEN=
# HF_HOME=/opt/sonilab/.cache/huggingface

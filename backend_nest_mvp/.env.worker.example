# ============================================================
# .env.worker.example — Portàtil Worker IA (CPU, de moment)
# ============================================================
# Copia a .env i ajusta els valors reals.
# Rol: processa jobs de transcripció i LLM. NO serveix HTTP.
# Connecta al MongoDB i Redis de la VM per agafar i completar jobs.
# ============================================================

NODE_ENV=production

# ── ROL ──────────────────────────────────────────────────────
# Worker: processa jobs però NO serveix API HTTP
WORKER_ENABLED=true
API_ENABLED=false

# ── MONGO / REDIS (de la VM) ─────────────────────────────────
# Substitueix 192.168.1.100 per la IP real de la VM Ubuntu
MONGO_URI=mongodb://192.168.1.100:27017/sonilab
REDIS_HOST=192.168.1.100
REDIS_PORT=6379

# ── STORAGE (NAS muntat — mateix que la VM) ──────────────────
# El portàtil ha de muntar la mateixa NAS al mateix path
# Ex: sudo mount -t cifs //srv-copy/d /mnt/sonilab_media -o ...
STORAGE_ROOT=/mnt/sonilab_media

# ── AUTH ─────────────────────────────────────────────────────
# Ha de ser el mateix JWT_SECRET que la VM (per verificar tokens)
JWT_SECRET=canvia_aquest_secret_llarg_i_aleatori
JWT_EXPIRES_IN=12h

# ── WHISPERX / TRANSCRIPCIÓ ──────────────────────────────────
# Python del venv local al portàtil
WHISPERX_PYTHON=/home/user/sonilab-worker-venv/bin/python
WHISPERX_RUNNER=/home/user/sonilab/WhisperX_Sonilab_01-main/src/runner_cli.py

WHISPERX_MODEL=large-v3
WHISPERX_ENGINE=faster-whisper
WHISPERX_PROFILE=VE
WHISPERX_LANGUAGE=es
WHISPERX_BATCH_SIZE=8
WHISPERX_DIARIZATION=false
WHISPERX_OFFLINE=false
WHISPERX_TIMING_FIX=true

# Device: cpu ara, cuda quan el portàtil tingui GPU compatible
TRANSCRIBE_DEVICE=cpu
WHISPERX_DEVICE=cpu
# TRANSCRIBE_DEVICE=cuda  ← descomentar quan hi hagi GPU

# ── OLLAMA / LLM ─────────────────────────────────────────────
# Ollama s'executa localment al portàtil
# Instal·lació: https://ollama.com/download
# Inici: ollama serve
# Model: ollama pull llama3.1
OLLAMA_BASE_URL=http://127.0.0.1:11434
# LLM_DEVICE=cpu  # (futur)

# ── OPCIONALS ────────────────────────────────────────────────
FFMPEG_BIN=/usr/bin/ffmpeg
# HUGGINGFACE_HUB_TOKEN=    # necessari per diarització
# HF_HOME=/home/user/.cache/huggingface
# PYTHON_RUNNER_DIR=/home/user/sonilab/WhisperX_Sonilab_01-main/src
